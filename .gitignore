#-----------------------------------------UNCLASSIFIED--------------------------------------------
# File: .gitignore
#
# Desc: A listing of files and directories that Git will ignore and not deal with.
#
# Hist: When       Who  What
#       02/25/2020 ptb  Initial code.
#-------------------------------------------------------------------------------------------------

# Ignore by extension.
#-------------------------------------------------------------------------------------------------
*.asv
*.exe
*.log
*.pdf
### *.jar # Keep jar files around.
*.zip
*.class
*.classpath
*.project

#
# Ignore directories by name.
#-------------------------------------------------------------------------------------------------
bin/
.venv/
.metadata/
eclipse-c/
__pycache__/
docs/MATLAB/
eclipse-java/
softwareUsed/
eclipse-python/
eclipse-sysmlv2/

#-------------------------------------------------------------------------------------------------
